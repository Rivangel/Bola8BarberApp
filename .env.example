# URL base de la API REST de Bola 8 Barbería (sin el sufijo /api).
# Las variables EXPO_PUBLIC_* se inyectan en el bundle de la app.
#
#   - Emulador Android:   http://10.0.2.2:3000   (valor por defecto en Android)
#   - Simulador iOS / web: http://localhost:3000  (valor por defecto)
#   - Dispositivo físico:  http://<IP-LOCAL-DE-TU-PC>:3000  (p. ej. http://192.168.1.50:3000)
#   - Producción (Vercel): https://bola8-barber-api.vercel.app
EXPO_PUBLIC_API_URL=http://localhost:3000
